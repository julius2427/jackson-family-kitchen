# ── Google OAuth ─────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Comma-separated list of emails allowed to sign in
ALLOWED_EMAILS=julius2427@gmail.com,wife@gmail.com

# NextAuth — generate: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
NEXTAUTH_SECRET=your-nextauth-secret
# Set to your Vercel URL in production
NEXTAUTH_URL=http://localhost:3000

# ── Backend API ───────────────────────────────────────────────────────────────
# Your Render service URL (no trailing slash)
API_URL=https://jackson-kitchen-api.onrender.com
# Must match API_SECRET_KEY on Render
API_SECRET_KEY=your-api-secret-key
